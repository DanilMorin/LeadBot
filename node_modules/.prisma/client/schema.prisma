generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model Lead {
  id         Int        @id @default(autoincrement())
  telegramId BigInt?
  name       String
  phone      String
  service    String
  comment    String?
  status     LeadStatus @default(NEW)
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
}

enum LeadStatus {
  NEW
  IN_PROGRESS
  CLOSED
}
